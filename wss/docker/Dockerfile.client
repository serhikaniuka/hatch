FROM python:3.13-slim

RUN groupadd -r wss && useradd -r -g wss -d /app -s /sbin/nologin wss

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY client/ ./client/
COPY client_manager/ ./client_manager/
COPY docker/docker-entrypoint-client.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

RUN mkdir -p /data && chown wss:wss /data
USER wss

ENTRYPOINT ["/entrypoint.sh"]
