# Public hostname of the WSS server (used for TLS cert CN and client connections).
# Must match the network alias in docker-compose.yml (Docker does not support
# variable substitution in network aliases, so that entry stays hardcoded and
# must be updated manually if you change this hostname).
WSS_EXTERNAL_HOST=

# Port exposed on the host machine (default: 8765)
WSS_PORT=8765
